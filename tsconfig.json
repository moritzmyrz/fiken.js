{
	"include": ["src/**/*"],
	"exclude": ["node_modules", "**/*.test.ts"],
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Node",
		"strict": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	}
}
